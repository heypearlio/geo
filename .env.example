# ============================================================
# ENV VARS — copy this to .env.local and fill in your values.
# Also add all of these to your Vercel project environment variables.
# ============================================================

# Flodesk — email marketing & lead capture
FLODESK_API_KEY=your_flodesk_api_key_here
FLODESK_SEGMENT_ID=your_flodesk_segment_id_here

# Meta (Facebook) Pixel — used for ad tracking
NEXT_PUBLIC_FB_PIXEL_ID=your_pixel_id_here

# AuditSky — powers the AI visibility report
AUDITSKY_API_KEY=your_auditsky_api_key_here

# Calendly — GEO funnel booking
# Update these two when switching salespeople — zero code changes needed.
GEO_CALENDLY_URL=https://calendly.com/hey-pearl/meet
NEXT_PUBLIC_GEO_CALENDLY_URL=https://calendly.com/hey-pearl/meet
# Comma-separated event name keywords the webhook uses to identify GEO strategy calls.
# Update to match the new salesperson's Calendly event type name.
GEO_CALENDLY_KEYWORDS=geo strategy call,meet with misti

# Flodesk segment for people who book a call (triggers post-booking email sequence)
FLODESK_BOOKED_SEGMENT_ID=your_booked_segment_id_here
